{erl_opts, [debug_info,
            warnings_as_errors,
            warn_unused_vars,
            warn_shadow_vars,
            warn_unused_import,
            warn_obsolete_guard]}.

{deps, []}.

{shell, [{apps, [node_agent]}, {config, "config/sys.config"}]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {ct_opts, [{sys_config, "config/sys.config"}]}
    ]}
]}.

{dialyzer, [
    {warnings, [unknown, unmatched_returns, error_handling]},
    {plt_apps, top_level_deps}
]}.
